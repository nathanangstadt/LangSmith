OPENAI_API_KEY=
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/agent_playground
APP_ENCRYPTION_KEY=

# --- Telemetry ---
# All agent telemetry is emitted as standard OpenTelemetry (OTEL) spans using gen_ai.* semantic conventions.
# Traces are always stored locally in Postgres regardless of the settings below.

# Option A: Export to LangSmith (simplest — just set these two vars)
#   The OTLP endpoint and headers are configured automatically.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agent-playground

# Option B: Export to the bundled Jaeger instance (included in docker-compose)
#   UI available at http://localhost:16686 after `docker compose up`
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318/v1/traces
OTEL_EXPORTER_OTLP_HEADERS=

# Option C: Export to any other OTLP-compatible backend (Grafana Tempo, etc.)
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
#   OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=agent-playground
# URL shown as the "Jaeger ↗" link in the UI — adjust if Jaeger runs elsewhere
JAEGER_UI_URL=http://localhost:16686

FRONTEND_ORIGIN=http://localhost:5174

# --- Debug ---
# Set to true to log raw OpenAI stream events and parsed output to backend logs.
# View with: docker compose logs -f backend
# LOG_LLM_TRAFFIC=false
